# Server
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=1
ENFORCE_HTTPS=true

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.example.com/qrMenuSaas?retryWrites=true&w=majority&tls=true
DB_ENCRYPTION_AT_REST=true

# Secrets - store real values in a secret manager, not git
SECRETS_PROVIDER=aws-secrets-manager
JWT_SECRET=replace-with-64-char-secret
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=mero-qr-api
JWT_AUDIENCE=mero-qr-client
QR_TOKEN_SECRET=replace-with-64-char-secret
FILE_ACCESS_SECRET=replace-with-64-char-secret
API_SIGNATURE_SECRET=replace-with-64-char-secret
REQUIRE_API_SIGNATURE=true

# Superadmin / VPN restriction
ENFORCE_SUPERADMIN_VPN=true
SUPERADMIN_IP_ALLOWLIST=10.0.0.*,203.0.113.10

# CORS / frontend
CORS_ORIGIN=https://app.example.com,https://admin.example.com
CLIENT_URL=https://app.example.com
ADMIN_URL=https://admin.example.com

# Backups
BACKUP_STORAGE_PATH=./secure_backups
BACKUP_ENCRYPTION_REQUIRED=true
BACKUP_ENCRYPTION_KEY=replace-with-64-char-hex-key
BACKUP_SIGNING_KEY=replace-with-64-char-secret
BACKUP_RETENTION_MAX=30
BACKUP_MAX_UPLOAD_BYTES=262144000
BACKUP_MAX_UNZIPPED_BYTES=524288000
BACKUP_MAX_ZIP_ENTRIES=500
ALLOW_STANDALONE_RESTORE=true
DISABLE_RESTORE_TRANSACTIONS=false
RESTORE_RATE_LIMIT_MAX=10
BACKUP_RATE_LIMIT_MAX=30
# Optional: BullMQ background restore workers
REDIS_URL=redis://127.0.0.1:6379
RESTORE_WORKER_CONCURRENCY=2
# Optional cloud backup (S3)
# AWS_S3_BACKUP_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
BACKUP_CLOUD_PROVIDER=local

# Upload scanning
SECURE_UPLOAD_PATH=./secure_uploads
MAX_FILE_SIZE=5242880
CLAMAV_ENABLED=true
CLAMSCAN_PATH=clamscan

# Cloudinary public media uploads
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-secret
SMTP_FROM=noreply@example.com
