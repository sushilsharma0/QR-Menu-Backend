{
    "name": "qr-menu-backend",
    "version": "1.0.0",
    "description": "Complete QR Menu SaaS Platform Backend",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node seed.js",
        "seed:reset": "node seed.js --reset",
        "security:audit": "npm audit --audit-level=high",
        "security:scan": "node ../scripts/security/secret-scan.js && node ../scripts/security/dependency-policy.js && node ../scripts/security/static-analysis.js",
        "security:prod": "node ../scripts/security/production-validate.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.76.10",
        "cloudinary": "^2.10.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "exceljs": "^4.4.0",
        "express": "^4.22.1",
        "express-async-handler": "^1.2.0",
        "express-rate-limit": "^6.11.2",
        "express-validator": "^7.3.2",
        "helmet": "^7.2.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "jszip": "^3.10.1",
        "mongoose": "^7.8.9",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.7",
        "qrcode": "^1.5.4",
        "slugify": "^1.6.9",
        "socket.io": "^4.8.3",
        "twilio": "^6.0.2",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
